{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(hugo:*)",
      "Bash(hugo server:*)",
      "Bash(hugo version)",
      "Bash(npm run:*)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(npx:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git rev-parse:*)",
      "Bash(git remote -v)",
      "Bash(git stash list)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(find . -type f:*)",
      "Bash(find . -name:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(file:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git commit --amend:*)"
    ]
  }
}
